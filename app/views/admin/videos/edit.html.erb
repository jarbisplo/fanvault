<div class="max-w-xl">
  <div class="mb-6">
    <%= link_to "← Videos", admin_videos_path, class: "text-zinc-500 hover:text-white text-sm" %>
  </div>

  <h1 class="text-2xl font-bold text-white mb-8">Edit Video</h1>

  <%= form_with model: [:admin, @video], multipart: true, class: "space-y-6" do |f| %>
    <% if @video.errors.any? %>
      <div class="bg-red-900/40 border border-red-700 rounded-xl p-4 text-sm text-red-300">
        <% @video.errors.full_messages.each do |msg| %><p>• <%= msg %></p><% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :title, "Title", class: "block text-sm font-medium text-gray-300 mb-2" %>
      <%= f.text_field :title, class: "w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500" %>
    </div>

    <div>
      <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-300 mb-2" %>
      <%= f.text_area :description, rows: 3, class: "w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-blue-500 resize-none" %>
    </div>

    <div>
      <%= f.label :category, "Category", class: "block text-sm font-medium text-gray-300 mb-2" %>
      <%= f.select :category,
          Video::CATEGORY_LABELS.map { |k, v| [v, k] },
          { include_blank: "— Select a category —", selected: @video.category },
          class: "w-full bg-zinc-900 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-red-500" %>
    </div>

    <% if @video.video_file.present? %>
      <div class="bg-zinc-700 rounded-xl p-4 text-sm text-zinc-500">
        ✓ Video already uploaded. Upload a new file to replace it.
      </div>
    <% end %>

    <div>
      <%= f.hidden_field :video_file_cache %>
      <%= f.label :video_file, "Replace Video (optional)", class: "block text-sm font-medium text-gray-300 mb-2" %>
      <%= f.file_field :video_file, accept: "video/*", id: "video-input-edit",
          class: "block w-full text-sm text-zinc-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:bg-zinc-700 file:text-gray-300 hover:file:bg-gray-700" %>
      <p id="edit-file-selected" class="hidden mt-2 text-sm text-green-400 font-medium"></p>
    </div>

    <!-- Free toggle -->
    <div class="flex items-center justify-between p-4 rounded-xl" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
      <div>
        <p class="text-sm font-semibold text-zinc-300">Free video</p>
        <p class="text-xs text-zinc-500 mt-0.5">Anyone can watch — no subscription required</p>
      </div>
      <label class="relative inline-flex items-center cursor-pointer">
        <%= f.check_box :free, class: "sr-only peer" %>
        <div class="w-11 h-6 rounded-full peer bg-zinc-700 peer-checked:bg-red-600 transition-colors after:content-[''] after:absolute after:top-0.5 after:left-[2px] after:bg-white after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:after:translate-x-full"></div>
      </label>
    </div>

    <div>
      <%= f.hidden_field :thumbnail_cache %>
      <%= f.label :thumbnail, "Replace Thumbnail (optional)", class: "block text-sm font-medium text-gray-300 mb-2" %>
      <%= f.file_field :thumbnail, accept: "image/*",
          class: "block w-full text-sm text-zinc-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:bg-zinc-700 file:text-gray-300 hover:file:bg-gray-700" %>
    </div>

    <%= f.submit "Save Changes",
        class: "w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3.5 rounded-2xl transition cursor-pointer" %>
  <% end %>
</div>

<script>
  document.getElementById('video-input-edit')?.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    const mb = (file.size / 1024 / 1024).toFixed(1);
    const el = document.getElementById('edit-file-selected');
    el.textContent = '✓ ' + file.name + ' (' + mb + ' MB) — will replace current video';
    el.classList.remove('hidden');
  });
</script>
