<div class="min-h-screen bg-black flex items-center justify-center px-4 py-10">
  <div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-black text-white">Train Like <span class="text-red-500">Dubi.</span></h1>
      <p class="text-zinc-400 text-sm mt-1">Create your account</p>
    </div>

    <!-- Form -->
    <div class="bg-zinc-900 rounded-2xl p-6">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

        <% if resource.errors.any? %>
          <div class="mb-4 bg-red-950 border border-red-800 rounded-xl px-4 py-3 text-sm text-red-400">
            <% resource.errors.full_messages.each do |msg| %>
              <p><%= msg %></p>
            <% end %>
          </div>
        <% end %>

        <!-- Name row -->
        <div class="flex gap-3 mb-4">
          <div class="flex-1">
            <%= f.label :first_name, "First Name", class: "block text-sm text-zinc-400 mb-1" %>
            <%= f.text_field :first_name,
                autocomplete: "given-name",
                placeholder: "Mauricio",
                class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
          </div>
          <div class="flex-1">
            <%= f.label :last_name, "Last Name", class: "block text-sm text-zinc-400 mb-1" %>
            <%= f.text_field :last_name,
                autocomplete: "family-name",
                placeholder: "Dubón",
                class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
          </div>
        </div>

        <!-- Username -->
        <div class="mb-4">
          <%= f.label :username, "Username", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.text_field :username,
              autofocus: true,
              autocomplete: "username",
              placeholder: "yourusername",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <!-- Email -->
        <div class="mb-4">
          <%= f.label :email, "Email", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.email_field :email,
              autocomplete: "email",
              placeholder: "you@email.com",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <!-- Password -->
        <div class="mb-4">
          <%= f.label :password, "Password", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.password_field :password,
              autocomplete: "new-password",
              placeholder: "Min. 6 characters",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <!-- Password Confirmation -->
        <div class="mb-6">
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.password_field :password_confirmation,
              autocomplete: "new-password",
              placeholder: "Repeat password",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <%= f.submit "Create Account",
            class: "w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-xl transition cursor-pointer" %>

      <% end %>
    </div>

    <!-- Links -->
    <div class="text-center mt-4 text-sm text-zinc-500">
      Already have an account?
      <%= link_to "Sign in", new_user_session_path, class: "text-red-400 hover:text-red-300" %>
    </div>

  </div>
</div>
