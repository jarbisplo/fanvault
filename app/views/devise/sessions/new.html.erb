<div class="min-h-screen bg-black flex items-center justify-center px-4">
  <div class="w-full max-w-sm">

    <!-- Logo -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-black text-white">Train Like <span class="text-red-500">Dubi.</span></h1>
      <p class="text-zinc-400 text-sm mt-1">Sign in to your account</p>
    </div>

    <!-- Form -->
    <div class="bg-zinc-900 rounded-2xl p-6">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <div class="mb-4">
          <%= f.label :login, "Username or Email", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.text_field :login,
              autofocus: true,
              autocomplete: "username",
              placeholder: "dubon or you@email.com",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <div class="mb-6">
          <%= f.label :password, "Password", class: "block text-sm text-zinc-400 mb-1" %>
          <%= f.password_field :password,
              autocomplete: "current-password",
              placeholder: "••••••••",
              class: "w-full bg-zinc-800 text-white rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-red-500 border border-zinc-700" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 mb-6">
            <%= f.check_box :remember_me, class: "rounded" %>
            <%= f.label :remember_me, "Remember me", class: "text-sm text-zinc-400" %>
          </div>
        <% end %>

        <%= f.submit "Sign In",
            class: "w-full bg-red-600 hover:bg-red-700 text-white font-bold py-3 rounded-xl transition cursor-pointer" %>

      <% end %>
    </div>

    <!-- Links -->
    <div class="text-center mt-4 text-sm text-zinc-500">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
